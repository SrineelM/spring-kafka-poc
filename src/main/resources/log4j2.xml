<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">
    <Properties>
        <!-- Log pattern includes:
             %d: High precision ISO8601 timestamp (nano-seconds)
             %sn: Global Sequence Number for out-of-order log reconstruction
             %X: Mapped Diagnostic Context (traceId, spanId) for distributed tracing
             %t: Thread name
        -->
        <Property name="LOG_PATTERN">%d{yyyy-MM-dd'T'HH:mm:ss.SSSSSSSSSXXX} [%15.15t] %-5level %logger{36} [seq=%sn, traceId=%X{traceId}, spanId=%X{spanId}] - %msg%n</Property>
    </Properties>

    <Appenders>
        <!-- Synchronous Console Appender -->
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="${LOG_PATTERN}"/>
        </Console>

        <!-- 
             ASYNC WRAPPER: 
             Routes logs to the console using a background thread.
             We use this for INFO, WARN, and DEBUG levels to maximize throughput.
        -->
        <Async name="AsyncConsole" bufferSize="1024">
            <AppenderRef ref="Console"/>
            <!-- 
                 CRITICAL: Deny ERROR level logs in the async appender. 
                 This ensures errors are NOT queued and instead follow the 
                 synchronous path defined in the Loggers section.
            -->
            <ThresholdFilter level="ERROR" onMatch="DENY" onMismatch="NEUTRAL"/>
        </Async>
    </Appenders>

    <Loggers>
        <!-- Default Root Logger -->
        <Root level="INFO">
            <!-- 
                 Route to the Async appender for standard logs.
                 The AsyncConsole appender filters out ERRORs.
            -->
            <AppenderRef ref="AsyncConsole"/>
            
            <!-- 
                 Route ERROR logs DIRECTLY to the synchronous Console appender.
                 The calling thread will wait for the write to finish, 
                 ensuring errors are captured even during a crash.
            -->
            <AppenderRef ref="Console" level="ERROR"/>
        </Root>

        <!-- Tune noisy 3rd party logs -->
        <Logger name="org.springframework.kafka" level="INFO" additivity="false">
             <AppenderRef ref="AsyncConsole"/>
             <AppenderRef ref="Console" level="ERROR"/>
        </Logger>
        <Logger name="org.apache.kafka" level="WARN" additivity="false">
             <AppenderRef ref="AsyncConsole"/>
             <AppenderRef ref="Console" level="ERROR"/>
        </Logger>
    </Loggers>
</Configuration>
